#include <iostream>
#include <Windows.h>

int fibonacci(int n) {
    if (n == 0) return 0;
    if (n == 1) return 1;

    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main() {

    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int n;

    std::cout << "Введите число: ";
    std::cin >> n;

    std::cout << "Числа Фибоначчи: ";

    for (int i = 0; i < n; i++) {
        std::cout << fibonacci(i) << " ";
    }

    return 0;
}
