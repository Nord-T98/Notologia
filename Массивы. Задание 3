#include <iostream>
#include <Windows.h>

int main() {
    
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int arr[3][6] = {
        {5, 2, 8, 1, 9, 3},
        {7, 4, 6, 12, 10, 11},
        {13, 14, 0, 16, 15, 18}
    };

    std::cout << "Массив:\n";

    // Вывод массива
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 6; j++) {
            std::cout << arr[i][j] << "\t";
        }
        std::cout << std::endl;
    }

    int min = arr[0][0];
    int max = arr[0][0];

    int minRow = 0, minCol = 0;
    int maxRow = 0, maxCol = 0;

    // Поиск min и max
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 6; j++) {
            if (arr[i][j] < min) {
                min = arr[i][j];
                minRow = i;
                minCol = j;
            }
            if (arr[i][j] > max) {
                max = arr[i][j];
                maxRow = i;
                maxCol = j;
            }
        }
    }

    std::cout << "Индекс минимального элемента: "
        << minRow << " " << minCol << std::endl;

    std::cout << "Индекс максимального элемента: "
        << maxRow << " " << maxCol << std::endl;

    return 0;
}
